[Unit]
Description=Monitor crypto CNY/USDT price difference
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/monitor-price
EnvironmentFile=-/etc/monitor-price/.env
ExecStart=/usr/bin/uwsgi --ini /etc/monitor-price/monitor_price.uwsgi.ini
Restart=always
RestartSec=10
KillSignal=SIGTERM
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
